# PS Store Deal Hunter Configuration
# Get your NPSSO token from: https://store.playstation.com (login, then visit https://ca.account.sony.com/api/v1/ssocookie)
NPSSO_TOKEN=your_npsso_token_here

# Server port (default: 3000)
PORT=3000

# Data refresh interval in minutes (default: 30)
REFRESH_INTERVAL=30

# Mode: 'demo' for demo data, 'live' for real PS Store data (requires NPSSO_TOKEN)
MODE=demo
